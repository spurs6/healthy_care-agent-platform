# OpenEvidence 临床证据助手 - 环境变量配置模板
# 请复制此文件为 .env 并填写实际值

# ==================== 硅基流动LLM配置 ====================
# 获取API密钥：https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# LLM参数
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1
LLM_STREAM_TIMEOUT=60

# ==================== PubMed API配置 ====================
# 获取API密钥：https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=your_pubmed_api_key_here

# ==================== Chunk切分参数 ====================
CHUNK_WINDOW=600
CHUNK_OVERLAP=150
MIN_CHUNK_TOKEN=200

# ==================== 检索参数 ====================
RECALL_TOP_K=10
RERANK_SCORE_THRESHOLD=0.4
FINAL_SEND_LLM_TOP=8

# ==================== 评测指标底线 ====================
FAITHFULNESS_MIN=0.8
CITATION_ACC_MIN=0.85

# ==================== 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false